# ==============================================================================
# Python
# ==============================================================================

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution and build artifacts
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Test and coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc
.tox/
.nox/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Linter / formatter
.ruff_cache/

# Environment variables (sensitive information)
.env
.env.*
!.env.example

# Log files
*.log
logs/

# ==============================================================================
# Docker
# ==============================================================================

# Docker environment variables (sensitive information)
.env
.env.local
.env.*.local

# Docker Compose override files (local custom settings)
docker-compose.override.yml
docker-compose.override.yaml

# Docker volume mount directories (local persistent data)
data/
postgres_data/
pgdata/

# Docker build cache (managed by BuildKit, no need to track)
.dockerignore

# ==============================================================================
# Operating System
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
